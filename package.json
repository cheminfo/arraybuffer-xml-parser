{
  "name": "arraybuffer-xml-parser",
  "version": "2.1.0",
  "description": "Parse XML files contained in an array buffer",
  "type": "module",
  "exports": {
    ".": "./lib/index.js"
  },
  "files": [
    "lib",
    "src"
  ],
  "scripts": {
    "build": "npm run tsc-build && cheminfo-build --entry lib/index.js --root XMLParser",
    "check-types": "tsc --noEmit",
    "clean": "rimraf lib lib-esm",
    "eslint": "eslint src",
    "eslint-fix": "npm run eslint -- --fix",
    "prepack": "npm run tsc",
    "prettier": "prettier --check src",
    "prettier-write": "prettier --write src",
    "test": "npm run test-only && npm run eslint && npm run prettier && npm run check-types",
    "test-only": "vitest run --coverage",
    "tsc": "npm run clean && npm run tsc-build",
    "tsc-build": "tsc --project tsconfig.build.json"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cheminfo/arraybuffer-xml-parser.git"
  },
  "keywords": [],
  "author": "Luc Patiny",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/cheminfo/arraybuffer-xml-parser/issues"
  },
  "homepage": "https://github.com/cheminfo/arraybuffer-xml-parser#readme",
  "devDependencies": {
    "@types/he": "^1.2.3",
    "@vitest/coverage-v8": "4.0.12",
    "@zakodium/tsconfig": "^1.0.2",
    "cheminfo-build": "^1.3.1",
    "eslint": "^9.39.1",
    "eslint-config-cheminfo-typescript": "^21.0.1",
    "globals": "^16.5.0",
    "he": "^1.2.0",
    "ml-spectra-processing": "^14.18.1",
    "pako": "^2.1.0",
    "prettier": "^3.6.2",
    "rimraf": "^6.1.2",
    "typescript": "^5.9.3",
    "uint8-base64": "^1.0.0",
    "vitest": "^4.0.12"
  },
  "dependencies": {
    "@types/node": "^24.10.1",
    "dynamic-typing": "^1.0.1"
  }
}
